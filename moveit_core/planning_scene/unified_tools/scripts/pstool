#!/usr/bin/env python3
"""
pstool - 主入口脚本
"""
import sys
import os

# 添加模块路径
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'src'))

def main():
    try:
        from ps_tools.cli import main as cli_main
        return cli_main()
    except ImportError as e:
        print(f"导入错误: {e}")
        print("请确保目录结构正确")
        return 1

if __name__ == "__main__":
    sys.exit(main())