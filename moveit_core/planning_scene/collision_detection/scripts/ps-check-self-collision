#!/usr/bin/env python3
"""
检查自碰撞（复合物体内部碰撞）
"""
import sys
import os
import argparse
import json
sys.path.append(os.path.expanduser('~/qingfu_moveit/moveit_core/planning_scene'))

# ========== 设置路径 ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
sys.path.insert(0, CORE_SRC)

DETECTION_SRC = os.path.join(MODULE_ROOT, 'src')
sys.path.insert(0, DETECTION_SRC)

OBJ_MODULE_ROOT = os.path.join(PROJECT_ROOT, 'collision_objects')
OBJ_SRC = os.path.join(OBJ_MODULE_ROOT, 'src')
sys.path.insert(0, OBJ_SRC)

from ps_core.scene_client import PlanningSceneClient
from ps_collision.collision_checker import CollisionChecker
from ps_objects.object_manager import ObjectManager

def main():
    parser = argparse.ArgumentParser(
        description="检查复合物体的自碰撞",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 检查单个复合物体的自碰撞
  %(prog)s "robot_arm"
  
  # 检查所有复合物体的自碰撞
  %(prog)s --all
  
  # 从文件读取复合物体列表
  %(prog)s --from-file composite_objects.txt
  
  # 详细输出碰撞详情
  %(prog)s "complex_machine" --verbose
  
  # JSON格式输出
  %(prog)s "assembly" --json
        """
    )
    
    # 物体参数
    parser.add_argument('object_id', type=str, nargs='?',
                       help='要检查的复合物体ID')
    
    # 检查模式
    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument('--all', '-a', action='store_true',
                          help='检查所有复合物体的自碰撞')
    mode_group.add_argument('--from-file', '-f', type=str,
                          help='从文件读取复合物体列表')
    mode_group.add_argument('--pattern', '-p', type=str,
                          help='使用通配符匹配物体')
    
    # 输出选项
    parser.add_argument('--json', '-j', action='store_true',
                       help='JSON格式输出')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细输出')
    parser.add_argument('--quiet', '-q', action='store_true',
                       help='安静模式')
    parser.add_argument('--threshold', '-t', type=float, default=0.01,
                       help='碰撞阈值（默认: 0.01m）')
    
    args = parser.parse_args()
    
    # 参数验证
    if not args.object_id and not args.all and not args.from_file and not args.pattern:
        print("错误：必须指定物体ID或使用--all/--from-file/--pattern")
        parser.print_help()
        return 1
    
    try:
        # 初始化
        client = PlanningSceneClient()
        checker = CollisionChecker(client)
        manager = ObjectManager(client)
        
        # 确定要检查的物体列表
        objects_to_check = []
        
        if args.all:
            # 检查所有物体（但只对有多个部件的检查）
            all_objects = manager.list_objects()
            objects_to_check = all_objects
            
        elif args.from_file:
            # 从文件读取
            with open(args.from_file, 'r') as f:
                objects_to_check = [line.strip() for line in f if line.strip()]
                
        elif args.pattern:            
            # 通配符匹配
            import fnmatch
            all_objects = manager.list_objects()
            pattern = args.pattern
            objects_to_check = [obj for obj in all_objects if fnmatch.fnmatch(obj, pattern)]
            
        else:
            # 单个物体
            objects_to_check = [args.object_id]
        
        if not objects_to_check:
            print("没有要检查的物体")
            return 0
        
        # 检查每个物体
        results = {
            "check_type": "self_collision",
            "checked_objects": objects_to_check,
            "collisions_found": 0,
            "detailed_results": [],
            "timestamp": time.strftime("%Y-%m-%d %H:%M:%S")
        }
        
        for obj_id in objects_to_check:
            if not args.quiet:
                print(f"\n检查物体: {obj_id}")
            
            collision, info = checker.check_self_collision(obj_id)
            
            if "error" in info:
                result = {
                    "object_id": obj_id,
                    "error": info["error"],
                    "collision": False
                }
                
                if not args.quiet:
                    print(f"  ⚠️  错误: {info['error']}")
                    
            else:
                result = {
                    "object_id": obj_id,
                    "collision": collision,
                    "part_count": info.get("part_count", 0),
                    "collision_details": info.get("collision_details", []),
                    "collision_count": len(info.get("collision_details", []))
                }
                
                if collision:
                    results["collisions_found"] += 1
                    
                    if not args.quiet:
                        print(f"  ❌ 发现自碰撞")
                        print(f"     部件数量: {result['part_count']}")
                        print(f"     碰撞数量: {result['collision_count']}")
                        
                        if args.verbose and result["collision_details"]:
                            print("     碰撞详情:")
                            for cd in result["collision_details"]:
                                print(f"       部件 {cd['part1']} ↔ 部件 {cd['part2']}: "
                                      f"距离 {cd['distance']:.4f}m (阈值: {cd['threshold']:.4f}m)")
                else:
                    if not args.quiet:
                        print(f"  ✅ 无自碰撞")
                        print(f"     部件数量: {result['part_count']}")
            
            results["detailed_results"].append(result)
        
        # 汇总输出
        if not args.quiet:
            print(f"\n{'='*50}")
            print(f"自碰撞检查汇总:")
            print(f"  检查物体数: {len(objects_to_check)}")
            print(f"  发现自碰撞: {results['collisions_found']}")
            print(f"  检查时间: {results['timestamp']}")
        
        if args.json:
            print(json.dumps(results, indent=2))
        
        # 返回状态码
        return 1 if results["collisions_found"] > 0 else 0
        
    except KeyboardInterrupt:
        print("\n操作被中断")
        return 130
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        return 1

if __name__ == "__main__":
    import time
    sys.exit(main())