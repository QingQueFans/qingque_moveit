#!/usr/bin/env python3
"""
列出 PlanningScene 中的所有碰撞物体 - pymoveit2 版
"""
import sys
import os
import argparse
import time
import fnmatch
import json

# ========== 路径设置（原样保留） ==========
sys.path.append(os.path.expanduser('~/qingfu_moveit/moveit_core/planning_scene'))

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
sys.path.insert(0, CORE_SRC)

OBJ_SRC = os.path.join(MODULE_ROOT, 'src')
sys.path.insert(0, OBJ_SRC)

# ========== 导入 ==========
# 需要导入 rclpy 和 MoveIt2
import rclpy
from rclpy.node import Node
from pymoveit2 import MoveIt2

# 你的模块
from ps_objects.object_manager import ObjectManager
from ps_objects.shape_generator import ShapeGenerator


def create_moveit2_node():
    """创建 MoveIt2 实例"""
    if not rclpy.ok():
        rclpy.init()
    
    node = Node("list_objects_node")
    
    moveit2 = MoveIt2(
        node=node,
        joint_names=["panda_joint1", "panda_joint2", "panda_joint3",
                     "panda_joint4", "panda_joint5", "panda_joint6", "panda_joint7"],
        base_link_name="panda_link0",
        end_effector_name="panda_hand",
        group_name="panda_arm"
    )
    
    return node, moveit2


def main():
    parser = argparse.ArgumentParser(
        description="列出 PlanningScene 中的所有碰撞物体",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 列出所有物体（简洁模式）
  %(prog)s
  
  # 列出详细信息
  %(prog)s --details
  
  # 列出详细信息并统计
  %(prog)s --details --count
  
  # 按名称排序
  %(prog)s --sort name
  
  # 按类型排序
  %(prog)s --sort type
  
  # 使用JSON格式输出
  %(prog)s --json
  
  # 导出到文件
  %(prog)s --export objects.json
  
  # 筛选特定类型的物体
  %(prog)s --filter "box"
  
  # 使用通配符筛选
  %(prog)s --filter "obstacle_*"
        """
    )
    
    # 显示模式选项
    parser.add_argument('--details', '-d', action='store_true',
                       help='显示详细信息')
    parser.add_argument('--count', '-c', action='store_true',
                       help='显示数量统计')
    parser.add_argument('--json', '-j', action='store_true',
                       help='以JSON格式输出')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细模式，包括空场景信息')
    parser.add_argument('--quiet', '-q', action='store_true',
                       help='安静模式，只输出物体ID')
    
    # 排序选项
    parser.add_argument('--sort', '-s', type=str, choices=['name', 'type', 'time', 'none'],
                       default='none', help='排序方式: name(名称), type(类型), time(时间), none(不排序)')
    
    # 筛选选项
    parser.add_argument('--filter', '-f', type=str,
                       help='筛选物体名称（支持通配符）')
    parser.add_argument('--type', '-t', type=str,
                       help='筛选物体类型（box, sphere, cylinder, cone等）')
    
    # 导出选项
    parser.add_argument('--export', '-e', type=str,
                       help='导出到指定文件')
    parser.add_argument('--format', type=str, choices=['json', 'csv', 'txt'],
                       default='json', help='导出格式（默认: json）')
    
    args = parser.parse_args()
    
    # 初始化 ROS2 和 MoveIt2
    node, moveit2 = create_moveit2_node()
    
    try:
        # 初始化管理器（用 moveit2 替代 client）
        manager = ObjectManager(moveit2)
        generator = ShapeGenerator()
        
        # 从缓存获取物体列表
        object_ids = manager.list_objects()
        
        if args.filter:
            filtered_ids = []
            pattern = args.filter
            for obj_id in object_ids:
                if fnmatch.fnmatch(obj_id, pattern):
                    filtered_ids.append(obj_id)
            object_ids = filtered_ids
        
        # 从缓存获取详细信息
        objects_info = []
        for obj_id in object_ids:
            obj_info = manager.get_object_from_cache(obj_id)
            if obj_info:
                obj_info['name'] = obj_id
                objects_info.append(obj_info)
        
        # 类型筛选
        if args.type:
            type_filter = args.type.lower()
            objects_info = [obj for obj in objects_info 
                          if obj.get('type', '').lower() == type_filter]
        
        # 排序
        if args.sort == 'name':
            objects_info.sort(key=lambda x: x['name'])
        elif args.sort == 'type':
            objects_info.sort(key=lambda x: x.get('type', 'unknown'))
        
        # 处理空场景
        if not objects_info:
            if args.verbose:
                print("场景中没有碰撞物体")
                print(f"缓存中有 {len(object_ids)} 个物体ID，但无法获取详细信息")
            elif not args.quiet:
                print("场景中没有碰撞物体")
            return 0
        
        # 显示模式
        if args.json:
            output_data = {
                'count': len(objects_info),
                'objects': objects_info,
                'timestamp': time.strftime("%Y-%m-%d %H:%M:%S")
            }
            
            if args.export:
                with open(args.export, 'w') as f:
                    json.dump(output_data, f, indent=2)
                if not args.quiet:
                    print(f"✅ 已导出到 {args.export}")
            else:
                print(json.dumps(output_data, indent=2))
                
        elif args.quiet:
            for obj_info in objects_info:
                print(obj_info['name'])
                
        elif args.details:
            print(f"碰撞物体列表 (共 {len(objects_info)} 个)")
            print("=" * 60)
            
            for i, obj_info in enumerate(objects_info, 1):
                print(f"{i:3d}. {obj_info['name']}")
                print(f"     类型: {obj_info.get('type', 'unknown')}")
                print(f"     尺寸: {obj_info.get('dimensions', [])}")
                print(f"     位置: {obj_info.get('position', [])}")
                print(f"     操作: {obj_info.get('operation', 'unknown')}")
                print(f"     参考坐标系: {obj_info.get('frame_id', 'unknown')}")
                print()        
        else:
            if args.count:
                print(f"场景中有 {len(objects_info)} 个碰撞物体:")
            
            for i, obj_info in enumerate(objects_info, 1):
                obj_type = obj_info.get('type', 'unknown')
                dimensions = obj_info.get('dimensions', [])
                
                if len(dimensions) == 3:
                    print(f"{i:3d}. {obj_info['name']} ({obj_type}, {dimensions[0]:.2f}x{dimensions[1]:.2f}x{dimensions[2]:.2f})")
                elif len(dimensions) == 1:
                    print(f"{i:3d}. {obj_info['name']} ({obj_type}, r={dimensions[0]:.2f})")
                elif len(dimensions) == 2:
                    print(f"{i:3d}. {obj_info['name']} ({obj_type}, r={dimensions[0]:.2f}, h={dimensions[1]:.2f})")
                else:
                    print(f"{i:3d}. {obj_info['name']} ({obj_type})")
        
        # 导出到其他格式
        if args.export and not args.json:
            try:
                if args.format == 'csv':
                    import csv
                    with open(args.export, 'w', newline='') as f:
                        writer = csv.writer(f)
                        writer.writerow(['Name', 'Type', 'Dimensions', 'Position', 'Frame ID'])
                        for obj_info in objects_info:
                            writer.writerow([
                                obj_info['name'],
                                obj_info.get('type', 'unknown'),
                                obj_info.get('dimensions', []),
                                obj_info.get('position', []),
                                obj_info.get('frame_id', 'unknown')
                            ])
                    
                elif args.format == 'txt':
                    with open(args.export, 'w') as f:
                        f.write(f"碰撞物体列表 - {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
                        f.write(f"物体总数: {len(objects_info)}\n")
                        f.write("=" * 40 + "\n")
                        for obj_info in objects_info:
                            f.write(f"- {obj_info['name']}\n")
                            f.write(f"  类型: {obj_info.get('type', 'unknown')}\n")
                            f.write(f"  尺寸: {obj_info.get('dimensions', [])}\n")
                            f.write(f"  位置: {obj_info.get('position', [])}\n\n")
                
                if not args.quiet:
                    print(f"✅ 已导出到 {args.export} ({args.format}格式)")
                    
            except Exception as e:
                print(f"❌ 导出失败: {e}")
                return 1
        
        return 0
        
    except KeyboardInterrupt:
        print("\n操作被中断")
        return 130
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        return 1
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    sys.exit(main())