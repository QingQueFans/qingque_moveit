#!/usr/bin/env python3
"""
列出 PlanningScene 中的所有碰撞物体
"""
import sys
import os
import argparse
import time
# 添加这一行
sys.path.append(os.path.expanduser('~/qingfu_moveit/moveit_core/planning_scene'))
# ========== 关键：设置正确的路径 ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))  # scripts/
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)                # collision_objects/
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)              # planning_scene/

# 添加 core_functions 的 src 到路径
CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
sys.path.insert(0, CORE_SRC)

# 添加 collision_objects 的 src 到路径
OBJ_SRC = os.path.join(MODULE_ROOT, 'src')
sys.path.insert(0, OBJ_SRC)

# 现在可以正常导入
from ps_core.scene_client import PlanningSceneClient
from ps_objects.object_manager import ObjectManager
from ps_objects.shape_generator import ShapeGenerator

def main():
    parser = argparse.ArgumentParser(
        description="列出 PlanningScene 中的所有碰撞物体",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 列出所有物体（简洁模式）
  %(prog)s
  
  # 列出详细信息
  %(prog)s --details
  
  # 列出详细信息并统计
  %(prog)s --details --count
  
  # 按名称排序
  %(prog)s --sort name
  
  # 按类型排序
  %(prog)s --sort type
  
  # 按创建时间排序
  %(prog)s --sort time
  
  # 使用JSON格式输出
  %(prog)s --json
  
  # 导出到文件
  %(prog)s --export objects.json
  
  # 筛选特定类型的物体
  %(prog)s --filter "box"
  
  # 使用通配符筛选
  %(prog)s --filter "obstacle_*"
  
  # 列出空场景信息
  %(prog)s --verbose
        """
    )
    
    # 显示模式选项
    parser.add_argument('--details', '-d', action='store_true',
                       help='显示详细信息')
    parser.add_argument('--count', '-c', action='store_true',
                       help='显示数量统计')
    parser.add_argument('--json', '-j', action='store_true',
                       help='以JSON格式输出')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细模式，包括空场景信息')
    parser.add_argument('--quiet', '-q', action='store_true',
                       help='安静模式，只输出物体ID')
    
    # 排序选项
    parser.add_argument('--sort', '-s', type=str, choices=['name', 'type', 'time', 'none'],
                       default='none', help='排序方式: name(名称), type(类型), time(时间), none(不排序)')
    
    # 筛选选项
    parser.add_argument('--filter', '-f', type=str,
                       help='筛选物体名称（支持通配符）')
    parser.add_argument('--type', '-t', type=str,
                       help='筛选物体类型（box, sphere, cylinder, cone等）')
    
    # 导出选项
    parser.add_argument('--export', '-e', type=str,
                       help='导出到指定文件')
    parser.add_argument('--format', type=str, choices=['json', 'csv', 'txt'],
                       default='json', help='导出格式（默认: json）')
    
    args = parser.parse_args()
    
    try:
        # 初始化客户端和工具
        client = PlanningSceneClient()
        manager = ObjectManager(client)
        generator = ShapeGenerator()
        
        # 获取所有物体
        object_ids = manager.list_objects()
        
        if args.filter:
            # 使用通配符筛选
            import fnmatch
            filtered_ids = []
            pattern = args.filter
            for obj_id in object_ids:
                if fnmatch.fnmatch(obj_id, pattern):
                    filtered_ids.append(obj_id)
            object_ids = filtered_ids        
        # 获取物体详细信息
        objects_info = []
        for obj_id in object_ids:
            obj_info = manager.get_object_info(obj_id)
            if obj_info:
                # 获取场景信息以判断创建时间（简化处理）
                scene = client.get_current_scene()
                obj_info['name'] = obj_id
                
                # 尝试推断类型（根据形状数量）
                if obj_info.get('primitive_count', 0) == 1:
                    obj_info['type_guess'] = 'single_shape'
                elif obj_info.get('primitive_count', 0) > 1:
                    obj_info['type_guess'] = 'composite'
                else:
                    obj_info['type_guess'] = 'unknown'
                
                objects_info.append(obj_info)
        
        # 类型筛选
        if args.type:
            if args.type.lower() == 'composite':
                objects_info = [obj for obj in objects_info if obj.get('type_guess') == 'composite']
            elif args.type.lower() == 'simple':
                objects_info = [obj for obj in objects_info if obj.get('type_guess') == 'single_shape']
        
        # 排序
        if args.sort == 'name':
            objects_info.sort(key=lambda x: x['name'])
        elif args.sort == 'type':
            objects_info.sort(key=lambda x: x.get('type_guess', 'unknown'))
        
        # 处理空场景
        if not objects_info:
            if args.verbose:
                print("场景中没有碰撞物体")
                print(f"场景状态: {len(object_ids)} 个物体ID，但无法获取详细信息")
            elif not args.quiet:
                print("场景中没有碰撞物体")
            return 0
        
        # 显示模式
        if args.json:
            # JSON格式输出
            import json
            output_data = {
                'count': len(objects_info),
                'objects': objects_info,
                'timestamp': time.strftime("%Y-%m-%d %H:%M:%S")
            }
            
            if args.export:
                with open(args.export, 'w') as f:
                    json.dump(output_data, f, indent=2)
                if not args.quiet:
                    print(f"已导出到 {args.export}")
            else:
                print(json.dumps(output_data, indent=2))
                
        elif args.quiet:
            # 安静模式：只输出ID
            for obj_info in objects_info:
                print(obj_info['name'])
                
        # 在显示详细信息的地方，添加：
        elif args.details:
            print(f"碰撞物体列表 (共 {len(objects_info)} 个)")
            print("=" * 60)
            
            for i, obj_info in enumerate(objects_info, 1):
                print(f"{i:3d}. {obj_info['name']}")
                
                # 尝试从缓存获取更多信息
                cached = manager.get_object_from_cache(obj_info['name'])
                if cached:
                    print(f"     类型: {cached.get('type', 'unknown')}")
                    print(f"     尺寸: {cached.get('dimensions', [])}")
                    print(f"     位置: {cached.get('position', [])}")
                else:
                    print(f"     类型: {obj_info.get('type_guess', 'unknown')}")
                
                print(f"     操作: {obj_info.get('operation', 'unknown')}")
                print(f"     参考坐标系: {obj_info.get('frame_id', 'unknown')}")
                print()        
        else:            
        # 默认简洁模式
            if args.count:
                print(f"场景中有 {len(objects_info)} 个碰撞物体:")
            
            for i, obj_info in enumerate(objects_info, 1):
                shape_count = obj_info.get('primitive_count', 0)
                type_str = obj_info.get('type_guess', 'unknown')
                
                if shape_count == 1:
                    print(f"{i:3d}. {obj_info['name']} (简单形状)")
                elif shape_count > 1:
                    print(f"{i:3d}. {obj_info['name']} (复合形状, {shape_count}个部件)")
                else:
                    print(f"{i:3d}. {obj_info['name']} (未知)")
        
        # 导出到其他格式
        if args.export and not args.json:
            try:
                if args.format == 'csv':
                    import csv
                    with open(args.export, 'w', newline='') as f:
                        writer = csv.writer(f)
                        writer.writerow(['Name', 'Type', 'Shape Count', 'Frame ID', 'Operation'])
                        for obj_info in objects_info:
                            writer.writerow([
                                obj_info['name'],
                                obj_info.get('type_guess', 'unknown'),
                                obj_info.get('primitive_count', 0),
                                obj_info.get('frame_id', 'unknown'),
                                str(obj_info.get('operation', 'unknown'))
                            ])
                    
                elif args.format == 'txt':
                    with open(args.export, 'w') as f:
                        f.write(f"碰撞物体列表 - {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
                        f.write(f"物体总数: {len(objects_info)}\n")
                        f.write("=" * 40 + "\n")
                        for obj_info in objects_info:
                            f.write(f"- {obj_info['name']}\n")
                            f.write(f"  类型: {obj_info.get('type_guess', 'unknown')}\n")
                            f.write(f"  形状数量: {obj_info.get('primitive_count', 0)}\n")
                            f.write(f"  参考系: {obj_info.get('frame_id', 'unknown')}\n\n")
                
                if not args.quiet:
                    print(f"✅ 已导出到 {args.export} ({args.format}格式)")
                    
            except Exception as e:
                print(f"❌ 导出失败: {e}")
                return 1
        
        return 0
        
    except KeyboardInterrupt:
        print("\n操作被中断")
        return 130
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        return 1

if __name__ == "__main__":
    sys.exit(main())