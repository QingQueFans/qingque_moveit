#!/usr/bin/env python3
"""
可视化碰撞检测结果
"""
import sys
import os
import argparse
import json
import time

# ========== 设置路径 ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

print(f"[DEBUG] 脚本目录: {SCRIPT_DIR}")
print(f"[DEBUG] 模块根目录: {MODULE_ROOT}")
print(f"[DEBUG] 项目根目录: {PROJECT_ROOT}")

# 添加路径并打印调试信息
CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
DETECTION_SRC = os.path.join(MODULE_ROOT, 'src')
OBJ_MODULE_ROOT = os.path.join(PROJECT_ROOT, 'collision_objects')
OBJ_SRC = os.path.join(OBJ_MODULE_ROOT, 'src')

paths_to_add = [CORE_SRC, DETECTION_SRC, OBJ_SRC]

for path in paths_to_add:
    if os.path.exists(path):
        print(f"[DEBUG] 添加路径: {path}")
        sys.path.insert(0, path)
    else:
        print(f"[DEBUG] 路径不存在: {path}")

# 打印当前sys.path查看
print(f"\n[DEBUG] 当前sys.path:")
for i, path in enumerate(sys.path[:10]):  # 只显示前10个
    print(f"  {i}: {path}")

# 尝试导入并捕获更多信息
try:
    print("\n[DEBUG] 尝试导入模块...")
    from ps_core.scene_client import PlanningSceneClient
    print("[DEBUG] ✓ 成功导入 PlanningSceneClient")
    
    from ps_viz.collision_viz import CollisionVisualizer
    print("[DEBUG] ✓ 成功导入 CollisionVisualizer")
    
    from ps_collision.collision_checker import CollisionChecker
    print("[DEBUG] ✓ 成功导入 CollisionChecker")
    
except ModuleNotFoundError as e:
    print(f"\n[DEBUG] ✗ 导入失败: {e}")
    
    # 尝试查找模块
    import importlib.util
    
    # 检查模块是否存在
    for path in sys.path:
        ps_collision_path = os.path.join(path, 'ps_collision')
        if os.path.exists(ps_collision_path):
            print(f"[DEBUG] 找到 ps_collision 在: {ps_collision_path}")
            # 列出目录内容
            if os.path.isdir(ps_collision_path):
                print(f"[DEBUG] ps_collision 目录内容:")
                for item in os.listdir(ps_collision_path):
                    print(f"  - {item}")
        else:
            collision_checker_path = os.path.join(path, 'collision_checker.py')
            if os.path.exists(collision_checker_path):
                print(f"[DEBUG] 找到 collision_checker.py 在: {collision_checker_path}")
    
    print(f"\n[DEBUG] 请检查以下路径是否包含 ps_collision:")
    for i, path in enumerate(sys.path[:10]):
        check_path = os.path.join(path, 'ps_collision')
        exists = "✓" if os.path.exists(check_path) else "✗"
        print(f"  {exists} {check_path}")
    
    sys.exit(1)
except ImportError as e:
    print(f"\n[DEBUG] ✗ 导入错误: {e}")
    import traceback
    traceback.print_exc()
    sys.exit(1)

print("[DEBUG] 所有模块导入成功!")