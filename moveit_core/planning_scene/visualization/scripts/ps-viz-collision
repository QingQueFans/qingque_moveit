#!/usr/bin/env python3
"""
可视化碰撞检测结果
"""
import sys
import os
import argparse
import json
import time

# ========== 设置路径 ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
sys.path.insert(0, CORE_SRC)

DETECTION_SRC = os.path.join(MODULE_ROOT, 'src')
sys.path.insert(0, DETECTION_SRC)

# 添加这一行（大约在第25行左右）：
COLLISION_DETECTION_SRC = os.path.join(PROJECT_ROOT, 'collision_detection', 'src')
sys.path.insert(0, COLLISION_DETECTION_SRC)  # 把这行加进去

OBJ_MODULE_ROOT = os.path.join(PROJECT_ROOT, 'collision_objects')
OBJ_SRC = os.path.join(OBJ_MODULE_ROOT, 'src')
sys.path.insert(0, OBJ_SRC)

from ps_core.scene_client import PlanningSceneClient
from ps_viz.collision_viz import CollisionVisualizer
from ps_collision.collision_checker import CollisionChecker

def main():
    parser = argparse.ArgumentParser(
        description="可视化碰撞检测结果",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 检查并可视化当前场景碰撞
  %(prog)s
  
  # 从文件加载碰撞结果并可视化
  %(prog)s --collision-file collisions.json
  
  # 可视化特定物体对的碰撞
  %(prog)s --objects "robot" "obstacle1"
  
  # 生成JSON可视化数据
  %(prog)s --json
  
  # 保存可视化数据到文件
  %(prog)s --output collision_viz.json
        """
    )
    
    # 输入选项
    parser.add_argument('--collision-file', '-f', type=str,
                       help='碰撞结果文件（JSON格式）')
    parser.add_argument('--objects', '-o', type=str, nargs=2,
                       help='检查特定物体对的碰撞')
    
    # 可视化选项
    parser.add_argument('--show-points', action='store_true',
                       help='显示碰撞点')
    parser.add_argument('--show-lines', action='store_true',
                       help='显示碰撞连线')
    parser.add_argument('--show-regions', action='store_true',
                       help='显示碰撞区域')
    parser.add_argument('--show-all', '-a', action='store_true',
                       help='显示所有可视化元素')
    
    # 输出选项
    parser.add_argument('--json', '-j', action='store_true',
                       help='JSON格式输出')
    parser.add_argument('--output', '-O', type=str,
                       help='保存可视化数据到文件')
    parser.add_argument('--summary', '-s', action='store_true',
                       help='只显示碰撞摘要')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细输出')
    parser.add_argument('--quiet', '-q', action='store_true',
                       help='安静模式')
    
    args = parser.parse_args()
    
    try:
        # 初始化
        client = PlanningSceneClient()
        visualizer = CollisionVisualizer(client)
        
        # 获取碰撞数据
        collision_results = {}
        
        if args.collision_file:
            # 从文件加载
            with open(args.collision_file, 'r') as f:
                collision_results = json.load(f)
        elif args.objects:
            # 检查特定物体对
            checker = CollisionChecker(client)
            obj1, obj2 = args.objects
            collision, details = checker.check_collision(obj1, obj2)
            
            collision_results = {
                "collisions": [{
                    "object1": obj1,
                    "object2": obj2,
                    "collision": collision,
                    "position": [0, 0, 0],  # 简化
                    "severity": "high" if collision else "low"
                }] if collision else [],
                "collision_pairs": [{
                    "object1": obj1,
                    "object2": obj2,
                    "collision": collision
                }] if collision else []
            }
        else:
            # 检查整个场景
            checker = CollisionChecker(client)
            collision_results = checker.check_scene_collisions()
        
        if not args.quiet:
            collisions = collision_results.get("collisions", [])
            collision_pairs = collision_results.get("collision_pairs", [])
            print(f"发现 {len(collisions)} 个碰撞点和 {len(collision_pairs)} 个碰撞对")
        
        # 构建可视化选项
        viz_options = {
            "show_points": args.show_points or args.show_all,
            "show_lines": args.show_lines or args.show_all,
            "show_regions": args.show_regions or args.show_all,
            "default_show": not (args.show_points or args.show_lines or args.show_regions or args.show_all)
        }        # 执行可视化
        start_time = time.time()
        result = visualizer.visualize_collisions(collision_results, viz_options)
        elapsed_time = time.time() - start_time
        
        if not result.get("success", False):
            if result.get("message"):
                print(f"ℹ️  {result.get('message')}")
            else:
                print(f"❌ 可视化失败: {result.get('error', '未知错误')}")
            return 0 if result.get("message") else 1
        
        # 输出结果
        if args.output:
            with open(args.output, 'w') as f:
                json.dump(result, f, indent=2, default=str)
            if not args.quiet:
                print(f"✅ 可视化数据已保存到: {args.output}")
        
        if args.json:
            print(json.dumps(result, indent=2, default=str))
        elif not args.quiet:
            _print_collision_visualization(result, args)
        
        # 显示性能信息
        if not args.quiet and not args.summary:
            print(f"\n可视化耗时: {elapsed_time:.3f}s")
        
        return 0
        
    except KeyboardInterrupt:
        print("\n操作被中断")
        return 130
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        return 1

def _print_collision_visualization(result, args):
    """打印碰撞可视化结果"""
    if args.summary:
        # 只显示摘要
        print(f"\n碰撞摘要:")
        print(f"  碰撞数量: {result.get('collision_count', 0)}")
        
        viz_data = result.get("visualization_data", {})
        if viz_data:
            print(f"  可视化元素:")
            print(f"    碰撞点: {len(viz_data.get('collision_points', []))}")
            print(f"    碰撞线: {len(viz_data.get('collision_lines', []))}")
            print(f"    碰撞区域: {len(viz_data.get('collision_regions', []))}")
    else:
        # 完整输出
        print("\n" + "="*60)
        print("碰撞可视化结果")
        print("="*60)
        
        collision_count = result.get("collision_count", 0)
        
        if collision_count == 0:
            print("✅ 没有发现碰撞")
        else:
            print(f"发现 {collision_count} 个碰撞")
            
            viz_data = result.get("visualization_data", {})
            if viz_data and args.verbose:
                # 显示碰撞点
                points = viz_data.get("collision_points", [])
                if points:
                    print(f"\n碰撞点 ({len(points)} 个):")
                    for i, point in enumerate(points[:5]):
                        position = point.get("position", [0,0,0])
                        severity = point.get("severity", "medium")
                        penetration = point.get("penetration_depth", 0.0)
                        
                        print(f"  {i+1}. 位置: [{position[0]:.3f}, {position[1]:.3f}, {position[2]:.3f}]")
                        print(f"     严重度: {severity}, 穿透深度: {penetration:.3f}m")
                
                # 显示碰撞对
                lines = viz_data.get("collision_lines", [])
                if lines:
                    print(f"\n碰撞对 ({len(lines)} 个):")
                    for i, line in enumerate(lines[:5]):
                        label = line.get("label", "未知")
                        print(f"  {i+1}. {label}")
        
        print(f"\n时间戳: {result.get('timestamp', '未知')}")

if __name__ == "__main__":
    sys.exit(main())