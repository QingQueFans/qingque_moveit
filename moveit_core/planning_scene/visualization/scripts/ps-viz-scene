#!/usr/bin/env python3
"""
可视化规划场景
"""
import sys
import os
import argparse
import json
import time

# ========== 设置路径 ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

CORE_SRC = os.path.join(PROJECT_ROOT, 'core_functions', 'src')
sys.path.insert(0, CORE_SRC)

DETECTION_SRC = os.path.join(MODULE_ROOT, 'src')
sys.path.insert(0, DETECTION_SRC)

OBJ_MODULE_ROOT = os.path.join(PROJECT_ROOT, 'collision_objects')
OBJ_SRC = os.path.join(OBJ_MODULE_ROOT, 'src')
sys.path.insert(0, OBJ_SRC)

from ps_core.scene_client import PlanningSceneClient
from ps_viz.scene_visualizer import SceneVisualizer
from ps_objects.object_manager import ObjectManager

def main():
    parser = argparse.ArgumentParser(
        description="可视化规划场景",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 可视化当前场景
  %(prog)s
  
  # 生成JSON可视化数据
  %(prog)s --json
  
  # 使用随机颜色方案
  %(prog)s --color-scheme random
  
  # 根据物体尺寸着色
  %(prog)s --color-scheme size_based
  
  # 调整透明度
  %(prog)s --opacity 0.5
  
  # 保存可视化数据到文件
  %(prog)s --output scene_viz.json
        """
    )
    
    # 可视化选项
    parser.add_argument('--color-scheme', choices=['type_based', 'random', 'size_based'], 
                       default='type_based', help='颜色方案（默认: type_based）')
    parser.add_argument('--view-type', choices=['overview', 'top', 'side', 'perspective'],
                       default='overview', help='视图类型')
    parser.add_argument('--opacity', type=float, default=0.7,
                       help='物体透明度（0.0-1.0，默认: 0.7）')
    parser.add_argument('--show-labels', action='store_true',
                       help='显示物体标签')
    
    # 输出选项
    parser.add_argument('--json', '-j', action='store_true',
                       help='JSON格式输出')
    parser.add_argument('--output', '-o', type=str,
                       help='保存可视化数据到文件')
    parser.add_argument('--summary', '-s', action='store_true',
                       help='只显示场景摘要')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细输出')
    parser.add_argument('--quiet', '-q', action='store_true',
                       help='安静模式')
    
    args = parser.parse_args()
    
    try:
        # 初始化
        client = PlanningSceneClient()
        visualizer = SceneVisualizer(client)
        manager = ObjectManager(client)
        
        # 构建可视化选项
        viz_options = {
            "color_scheme": args.color_scheme,
            "view_type": args.view_type,
            "opacity": args.opacity,
            "show_labels": args.show_labels
        }
        
        if not args.quiet:
            print("正在可视化规划场景...")
            print(f"颜色方案: {args.color_scheme}")
            print(f"视图类型: {args.view_type}")
        
        # 执行可视化
        start_time = time.time()
        result = visualizer.visualize_scene(viz_options)
        elapsed_time = time.time() - start_time
        
        if not result.get("success", False):
            print(f"❌ 可视化失败: {result.get('error', '未知错误')}")
            return 1        # 输出结果
        if args.output:
            with open(args.output, 'w') as f:
                json.dump(result, f, indent=2, default=str)
            if not args.quiet:
                print(f"✅ 可视化数据已保存到: {args.output}")
        
        if args.json:
            print(json.dumps(result, indent=2, default=str))
        elif not args.quiet:
            _print_scene_visualization(result, args)
        
        # 显示性能信息
        if not args.quiet and not args.summary:
            print(f"\n可视化耗时: {elapsed_time:.3f}s")
        
        return 0
        
    except KeyboardInterrupt:
        print("\n操作被中断")
        return 130
    except Exception as e:
        print(f"错误: {e}")
        import traceback
        traceback.print_exc()
        return 1

def _print_scene_visualization(result, args):
    """打印场景可视化结果"""
    if args.summary:
        # 只显示摘要
        analysis = result.get("scene_analysis", {})
        if analysis:
            print(f"\n场景摘要:")
            print(f"  物体总数: {analysis.get('total_objects', 0)}")
            
            obj_types = analysis.get("object_types", {})
            if obj_types:
                print(f"  物体类型分布:")
                for obj_type, count in obj_types.items():
                    print(f"    {obj_type}: {count} 个")
            
            pos_stats = analysis.get("position_stats", {})
            if pos_stats:
                print(f"  位置范围:")
                print(f"    最小值: {pos_stats.get('min', [0,0,0])}")
                print(f"    最大值: {pos_stats.get('max', [0,0,0])}")
                print(f"    中心点: {pos_stats.get('center', [0,0,0])}")
    else:
        # 完整输出
        print("\n" + "="*60)
        print("场景可视化结果")
        print("="*60)
        
        analysis = result.get("scene_analysis", {})
        viz_data = result.get("visualization_data", {})
        
        # 显示场景分析
        if analysis:
            print(f"\n场景分析:")
            print(f"  物体总数: {analysis.get('total_objects', 0)}")
            
            obj_types = analysis.get("object_types", {})
            if obj_types:
                print(f"  物体类型分布:")
                for obj_type, count in obj_types.items():
                    print(f"    - {obj_type}: {count} 个")
            
            pos_stats = analysis.get("position_stats", {})
            if pos_stats:
                print(f"  位置范围:")
                print(f"    X: {pos_stats.get('min', [0,0,0])[0]:.2f} ~ {pos_stats.get('max', [0,0,0])[0]:.2f}")
                print(f"    Y: {pos_stats.get('min', [0,0,0])[1]:.2f} ~ {pos_stats.get('max', [0,0,0])[1]:.2f}")
                print(f"    Z: {pos_stats.get('min', [0,0,0])[2]:.2f} ~ {pos_stats.get('max', [0,0,0])[2]:.2f}")
        
        # 显示可视化数据
        if viz_data and args.verbose:
            objects = viz_data.get("objects", [])
            if objects:
                print(f"\n物体列表 ({len(objects)} 个):")
                for obj in objects[:10]:  # 只显示前10个
                    obj_id = obj.get("id", "unknown")
                    obj_type = obj.get("type", "unknown")
                    position = obj.get("position", [0,0,0])
                    color = obj.get("color", [1,1,1,1])
                    
                    print(f"  {obj_id:20s} {obj_type:10s} 位置: [{position[0]:.2f}, {position[1]:.2f}, {position[2]:.2f}]")
                
                if len(objects) > 10:
                    print(f"  ... 还有 {len(objects) - 10} 个物体未显示")
        
        print(f"\n时间戳: {result.get('timestamp', '未知')}")

if __name__ == "__main__":
    sys.exit(main())