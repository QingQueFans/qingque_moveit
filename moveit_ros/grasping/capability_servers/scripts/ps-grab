#!/usr/bin/env python3
"""
ps-grab: 智能抓取命令行工具
基于指南中的功能设计
"""

import sys
import os
import argparse
import time
import json

# ========== 路径设置（按照你的参考修正） ==========
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULE_ROOT = os.path.dirname(SCRIPT_DIR)
PROJECT_ROOT = os.path.dirname(MODULE_ROOT)

print(f"[脚本] 脚本目录: {SCRIPT_DIR}")
print(f"[脚本] 模块根目录: {MODULE_ROOT}")
print(f"[脚本] 项目根目录: {PROJECT_ROOT}")

# 找到moveit_ros根目录
current_dir = os.path.dirname(PROJECT_ROOT)
while current_dir:
    dir_name = os.path.basename(current_dir)
    if dir_name == 'moveit_ros':
        MOVEIT_ROS_ROOT = current_dir
        MOVEIT_CORE_ROOT = os.path.join(os.path.dirname(current_dir), 'moveit_core')
        MOVEIT_PLUGINS_ROOT = os.path.join(os.path.dirname(current_dir), 'moveit_plugins')
        break
    current_dir = os.path.dirname(current_dir)

# 设置路径
PLANNING_SCENE_SRC = os.path.join(MOVEIT_CORE_ROOT, 'planning_scene', 'core_functions', 'src')
PLANNING_SCENE_SRCQ = os.path.join(MOVEIT_CORE_ROOT, 'planning_scene', 'unified_tools', 'src')
MOVEIT_CONTROLLER_SRC = os.path.join(MOVEIT_PLUGINS_ROOT, 'moveit_controller_manager', 'src')
TRAJECTORY_EXECUTION_SRC = os.path.join(MODULE_ROOT, 'src')

sys.path.insert(0, TRAJECTORY_EXECUTION_SRC)
sys.path.insert(0, MOVEIT_CONTROLLER_SRC)
sys.path.insert(0, PLANNING_SCENE_SRC)
sys.path.insert(0, PLANNING_SCENE_SRCQ)

print(f"[脚本] 路径设置:")
print(f"  当前模块: {TRAJECTORY_EXECUTION_SRC}")
print(f"  控制器管理器: {MOVEIT_CONTROLLER_SRC}")
print(f"  规划场景: {PLANNING_SCENE_SRC}")

# 还需要添加其他必要的路径
CACHE_SRC = os.path.join(MOVEIT_CORE_ROOT, 'cache_manager', 'src')
OBJ_SRC = os.path.join(MOVEIT_CORE_ROOT, 'planning_scene', 'collision_objects', 'src')
sys.path.insert(0, CACHE_SRC)
sys.path.insert(0, OBJ_SRC)
try:
    from capability_servers_core import (
        quick_grab,      # 快速抓取（毫米单位）
        smart_grab,      # 智能抓取（自动计算）
        release_object,  # 释放物体
        get_grasp_status # 获取状态
    )
    print("✓ 抓取接口导入成功")
except ImportError as e:
    print(f"❌ 导入失败: {e}")
    sys.exit(1)


def print_banner():
    """打印工具横幅"""
    print("=" * 60)
    print("🤖 智能抓取命令行工具")
    print("=" * 60)
    print("功能：")
    print("  • 快速抓取（手动指定宽度）")
    print("  • 智能抓取（自动计算最佳宽度）")
    print("  • 释放物体")
    print("  • 状态查询")
    print("=" * 60)


def grab_command(args):
    """执行抓取命令"""
    print(f"🎯 目标物体: {args.object_id}")
    
    start_time = time.time()
    
    if args.auto:
        # 智能抓取模式
        print("🧠 模式: 智能抓取（自动计算宽度）")
        if args.strategy != 'auto':
            print(f"⚙️  策略: {args.strategy}")
        
        result = smart_grab(args.object_id, strategy=args.strategy)
        width_source = result.get('width_source', 'unknown')
        
    else:
        # 快速抓取模式
        print(f"📏 模式: 快速抓取（指定宽度 {args.width}mm）")
        result = quick_grab(args.object_id, width_mm=args.width)
        width_source = 'specified'
    
    elapsed_time = time.time() - start_time
    
    # 输出结果
    if args.json:
        result['elapsed_time'] = elapsed_time
        result['command'] = 'grab'
        print(json.dumps(result, indent=2, default=str))
    else:
        if result.get('success', False):
            print(f"✅ 抓取成功！")
            
            if 'grasp_width' in result:
                width_mm = result['grasp_width'] * 1000
                print(f"📏 实际宽度: {width_mm:.1f}mm")
            
            if width_source != 'unknown':
                print(f"🔧 宽度来源: {width_source}")
            
            print(f"⏱️  耗时: {elapsed_time:.2f}秒")
            print(f"🕒 时间戳: {result.get('timestamp', 'N/A')}")
            
            # 显示智能计算的详细信息
            if args.auto and args.verbose:
                if 'message' in result:
                    print(f"💬 消息: {result['message']}")
        else:
            print(f"❌ 抓取失败！")
            print(f"💔 错误: {result.get('error', '未知错误')}")
            print(f"⚙️  操作: {result.get('operation', 'unknown')}")
    
    return 0 if result.get('success', False) else 1


def release_command(args):
    """执行释放命令"""
    if args.object_id:
        print(f"🔄 释放物体: {args.object_id}")
    else:
        print("🔄 释放当前连接物体")
    
    print(f"📏 释放后宽度: {args.width}mm")
    
    start_time = time.time()
    result = release_object(args.object_id, width_mm=args.width)
    elapsed_time = time.time() - start_time
    
    if args.json:
        result['elapsed_time'] = elapsed_time
        result['command'] = 'release'
        print(json.dumps(result, indent=2, default=str))
    else:
        if result.get('success', False):
            print(f"✅ 释放成功！")
            print(f"⏱️  耗时: {elapsed_time:.2f}秒")
            
            if args.verbose:
                print(f"💬 消息: {result.get('message', 'N/A')}")
                print(f"🕒 时间戳: {result.get('timestamp', 'N/A')}")
        else:
            print(f"❌ 释放失败！")
            print(f"💔 错误: {result.get('error', '未知错误')}")
    
    return 0 if result.get('success', False) else 1


def status_command(args):
    """执行状态命令"""
    print("📊 抓取服务器状态")
    print("-" * 40)
    
    status = get_grasp_status()
    
    if args.json:
        print(json.dumps(status, indent=2, default=str))
    else:
        print(f"服务器: {status.get('server', 'unknown')}")
        print(f"活动状态: {'✅ 运行中' if status.get('active') else '❌ 停止'}")
        print(f"夹爪就绪: {'✅ 就绪' if status.get('gripper_ready') else '❌ 未就绪'}")
        
        attached_obj = status.get('attached_object')
        print(f"连接物体: {attached_obj if attached_obj else '🈚 无'}")
        
        print(f"时间戳: {status.get('timestamp', 'N/A')}")
        
        if args.verbose:            # 显示额外信息
            print(f"\n🔍 详细信息:")
            for key, value in status.items():
                if key not in ['server', 'active', 'gripper_ready', 'attached_object', 'timestamp']:
                    print(f"  {key}: {value}")
    
    return 0


def main():
    """主函数"""
    parser = argparse.ArgumentParser(
        description='智能抓取命令行工具',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  %(prog)s grab qingque                    # 快速抓取（默认60mm）
  %(prog)s grab qingque --width 50         # 抓取，指定50mm宽度
  %(prog)s grab qingque --auto             # 智能抓取（自动计算）
  %(prog)s grab qingque --auto --strategy side_grasp  # 指定抓取策略
  %(prog)s release qingque                 # 释放物体
  %(prog)s release --width 100             # 释放当前物体，张开100mm
  %(prog)s status                          # 查看状态
  %(prog)s status --verbose                # 详细状态

智能抓取说明:
  --auto 选项会调用 GripperCalculator 自动计算最佳夹爪宽度
  需要物体已在规划场景中，且有正确的尺寸信息
        """
    )
    
    # 子命令
    subparsers = parser.add_subparsers(dest='command', help='可用命令')
    subparsers.required = True
    
    # grab命令
    grab_parser = subparsers.add_parser('grab', help='抓取物体')
    grab_parser.add_argument('object_id', help='物体ID')
    
    grab_mode = grab_parser.add_mutually_exclusive_group()
    grab_mode.add_argument('--width', type=float, default=60.0,
                         help='夹爪宽度 (mm, 默认: 60)')
    grab_mode.add_argument('--auto', action='store_true',
                         help='智能抓取（自动计算宽度）')
    
    grab_parser.add_argument('--strategy', choices=['auto', 'side_grasp', 'top_grasp'],
                           default='auto', help='抓取策略（使用--auto时有效）')
    grab_parser.add_argument('--verbose', '-v', action='store_true',
                           help='详细输出')
    grab_parser.add_argument('--json', action='store_true',
                           help='JSON格式输出')
    
    # release命令
    release_parser = subparsers.add_parser('release', help='释放物体')
    release_parser.add_argument('object_id', nargs='?', default=None,
                              help='物体ID (可选，不提供则释放当前物体)')
    release_parser.add_argument('--width', type=float, default=80.0,
                              help='释放后夹爪宽度 (mm, 默认: 80)')
    release_parser.add_argument('--verbose', '-v', action='store_true',
                              help='详细输出')
    release_parser.add_argument('--json', action='store_true',
                              help='JSON格式输出')
    
    # status命令
    status_parser = subparsers.add_parser('status', help='查看状态')
    status_parser.add_argument('--verbose', '-v', action='store_true',
                             help='详细输出')
    status_parser.add_argument('--json', action='store_true',
                             help='JSON格式输出')
    
    # 如果没有参数，显示帮助
    if len(sys.argv) == 1:
        print_banner()
        parser.print_help()
        return 0
    
    args = parser.parse_args()
    
    try:
        if not args.json:
            print_banner()
        
        if args.command == 'grab':
            return grab_command(args)
        elif args.command == 'release':
            return release_command(args)
        elif args.command == 'status':
            return status_command(args)
        else:
            parser.print_help()
            return 0
            
    except KeyboardInterrupt:
        if not args.json:
            print("\n\n操作被中断")
        return 130
    except Exception as e:
        if args.json:
            print(json.dumps({
                "success": False,
                "error": str(e),
                "command": args.command if hasattr(args, 'command') else 'unknown'
            }, indent=2))
        else:
            print(f"❌ 错误: {e}")
        return 1


if __name__ == "__main__":
    sys.exit(main())