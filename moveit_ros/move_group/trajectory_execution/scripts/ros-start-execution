    if os.path.exists(path) and path not in sys.path:
        sys.path.insert(0, path)
        added_paths.append(path)

print(f"[轨迹执行] 路径设置完成，添加了 {len(added_paths)} 个路径")
if added_paths:
    print(f"  包含: {[os.path.basename(p) for p in added_paths[:3]]}...")
PYMOVEIT2_PATH = '/home/diyuanqiongyu/qingfu_moveit/install/pymoveit2/local/lib/python3.10/dist-packages'
sys.path.insert(0, PYMOVEIT2_PATH)
# ========== 导入检查 ==========
