#!/usr/bin/env python3
"""
plan-object: 物体管理命令行工具（带子命令）
支持：添加、移除、清空、列出、查询
"""

import sys
import os
import argparse
import json

# ========== 暴力引入路径 ==========
sys.path.insert(0, "/home/diyuanqiongyu/qingfu_moveit")
sys.path.insert(0, "/home/diyuanqiongyu/qingfu_moveit/moveit_ros/planning_interface/src")

import moveit_bootstrap
from planning_interface import Task


def main():
    parser = argparse.ArgumentParser(
        description="物体管理工具",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
示例:
  # 添加立方体
  plan-object add box test_box --position 0.5 0 0.3 --size 0.1 0.1 0.1
  
  # 添加球体
  plan-object add sphere ball --position 0.3 0.2 0.1 --radius 0.05
  
  # 添加圆柱体
  plan-object add cylinder can --position 0.6 0 0.2 --radius 0.03 --height 0.1
  
  # 移除物体
  plan-object remove test_box
  
  # 清空场景
  plan-object clear
  
  # 列出所有物体
  plan-object list
  
  # 查看物体信息
  plan-object info test_box
  
  # JSON 格式输出
  plan-object list --json
        """
    )
    
    subparsers = parser.add_subparsers(dest="command", required=True,
                                       help="子命令")
    
    # ===== add 子命令 =====
    add_parser = subparsers.add_parser("add", help="添加物体")
    add_parser.add_argument("type", choices=["box", "sphere", "cylinder"],
                           help="物体类型")
    add_parser.add_argument("object_id", help="物体ID")
    add_parser.add_argument("--position", type=float, nargs=3, required=True,
                           help="位置 x y z")
    add_parser.add_argument("--size", type=float, nargs=3,
                           help="立方体尺寸 长宽高")
    add_parser.add_argument("--radius", type=float,
                           help="半径（球体/圆柱体）")
    add_parser.add_argument("--height", type=float,
                           help="高度（圆柱体）")
    add_parser.add_argument("--orientation", type=float, nargs=4,
                           default=[0,0,0,1],
                           help="姿态四元数 (默认: 0 0 0 1)")
    
    # ===== remove 子命令 =====
    remove_parser = subparsers.add_parser("remove", help="移除物体")
    remove_parser.add_argument("object_id", help="物体ID")
    
    # ===== clear 子命令 =====
    clear_parser = subparsers.add_parser("clear", help="清空场景")
    
    # ===== list 子命令 =====
    list_parser = subparsers.add_parser("list", help="列出所有物体")
    list_parser.add_argument("--json", action="store_true",
                            help="JSON格式输出")
    
    # ===== info 子命令 =====
    info_parser = subparsers.add_parser("info", help="查看物体信息")
    info_parser.add_argument("object_id", help="物体ID")
    info_parser.add_argument("--json", action="store_true",
                            help="JSON格式输出")
    
    # 通用选项
    parser.add_argument("--verbose", "-v", action="store_true",
                       help="详细输出")
    
    args = parser.parse_args()
    
    # 创建任务
    task = Task("object_manager")
    
    # 处理子命令
    if args.command == "add":
        if args.type == "box":
            if not args.size:
                print("❌ 立方体需要 --size 参数")
                sys.exit(1)
            result = task.add_object(args.object_id, args.position, args.size,
                                   orientation=args.orientation)
        elif args.type == "sphere":
            if not args.radius:
                print("❌ 球体需要 --radius 参数")
                sys.exit(1)
            result = task.add_sphere(args.object_id, args.position,
                                   args.radius, args.orientation)
        elif args.type == "cylinder":
            if not args.radius or not args.height:
                print("❌ 圆柱体需要 --radius 和 --height 参数")
                sys.exit(1)
            result = task.add_cylinder(args.object_id, args.position,
                                     args.radius, args.height, args.orientation)
    
    elif args.command == "remove":
        result = task.remove_object(args.object_id)
    
    elif args.command == "clear":
        result = task.clear_scene()
    
    elif args.command == "list":
        objects = task.list_objects()
        if args.json:
            print(json.dumps(objects, indent=2))
        else:
            print(f"📦 场景中有 {len(objects)} 个物体:")
            for obj in objects:
                print(f"  - {obj}")
        return
    
    elif args.command == "info":
        info = task.get_object_info(args.object_id)
        if args.json:
            print(json.dumps(info, indent=2) if info else "{}")
        else:
            if info:
                print(f"📋 物体 {args.object_id} 信息:")
                for k, v in info.items():
                    print(f"  {k}: {v}")
            else:
                print(f"❌ 未找到物体 {args.object_id}")
                sys.exit(1)
        return
    
    # 输出结果（用于 add/remove/clear）
    if hasattr(args, 'json') and args.json:
        print(json.dumps(result, indent=2))
    else:
        if result.get("success"):
            print(f"✅ 操作成功")
            if args.verbose:
                print(f"   耗时: {result.get('elapsed_time', 0):.2f}s")
        else:
            print(f"❌ 操作失败: {result.get('error', '未知错误')}")
            sys.exit(1)


if __name__ == "__main__":
    main()