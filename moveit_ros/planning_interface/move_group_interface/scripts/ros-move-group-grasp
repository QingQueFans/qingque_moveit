    sys.exit(1)


def parse_arguments():
    """解析命令行参数"""
    parser = argparse.ArgumentParser(
        description='机械臂抓取控制工具 - 基于三级模块接口',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
使用示例:
  %(prog)s grasp --object qingque                    # 抓取物体（规划器全权负责）
  %(prog)s grasp --pose 0.5 0.0 0.3 0 0 0 1          # 抓取指定位姿
  %(prog)s move --pose 0.6 0.2 0.4 0 0 0 1           # 移动到指定位姿
  %(prog)s move --joints 0 -0.5 0 -1.5 0 1.5 0       # 移动到关节位置
  %(prog)s batch --objects part1 part2 part3          # 批量抓取
  %(prog)s status                                      # 查看当前任务状态
  %(prog)s cache --stats                               # 查看缓存统计
  %(prog)s cache --clear                               # 清空缓存
  %(prog)s release --object qingque                    # 释放物体
        """
    )
    
    # 主命令
    subparsers = parser.add_subparsers(dest='command', required=True,
                                       help='可用命令')
    
    # ===== grasp 命令 =====
    grasp_parser = subparsers.add_parser('grasp', help='抓取物体')
    
    # 目标类型（互斥）
    target_group = grasp_parser.add_mutually_exclusive_group(required=True)
    target_group.add_argument('--object', type=str, metavar='ID',
                            help='物体ID（已在场景中）')
    target_group.add_argument('--pose', type=float, nargs=7,
                            help='抓取位姿 [x y z qx qy qz qw]')
    
    grasp_parser.add_argument('--strategy', type=str, 
                            choices=['top_grasp', 'side_grasp'],
                            default='top_grasp',
                            help='抓取策略 (默认: top_grasp)')
    grasp_parser.add_argument('--width', type=float, metavar='mm',
                            help='手动指定夹爪宽度(毫米)')
    grasp_parser.add_argument('--timeout', type=float, default=8.0,
                            help='规划超时时间(秒) (默认: 8.0)')
    
    # ===== move 命令 =====
    move_parser = subparsers.add_parser('move', help='移动机械臂')
    
    # 目标类型（互斥）
    move_target = move_parser.add_mutually_exclusive_group(required=True)
    move_target.add_argument('--pose', type=float, nargs=7,
                           help='目标位姿 [x y z qx qy qz qw]')
    move_target.add_argument('--joints', type=float, nargs=7,
                           help='目标关节角度 [j1-j7]')
    move_target.add_argument('--object', type=str,
                           help='移动到物体位置')
    
    move_parser.add_argument('--timeout', type=float, default=5.0,
                           help='规划超时时间(秒) (默认: 5.0)')
    move_parser.add_argument('--no-cache', action='store_true',
                           help='禁用缓存')
    
    # ===== batch 命令 =====
    batch_parser = subparsers.add_parser('batch', help='批量抓取')
    batch_parser.add_argument('--objects', type=str, nargs='+', required=True,
                            help='物体ID列表')
    batch_parser.add_argument('--strategy', type=str, default='top_grasp',
                            choices=['top_grasp', 'side_grasp'],
                            help='抓取策略 (默认: top_grasp)')
    
    # ===== status 命令 =====
    status_parser = subparsers.add_parser('status', help='查看当前任务状态')
    
    # ===== cache 命令 =====
    cache_parser = subparsers.add_parser('cache', help='缓存管理')
    cache_group = cache_parser.add_mutually_exclusive_group(required=True)
    cache_group.add_argument('--stats', action='store_true',
                           help='查看缓存统计')
    cache_group.add_argument('--clear', action='store_true',
                           help='清空缓存')
    
    # ===== release 命令 =====
    release_parser = subparsers.add_parser('release', help='释放物体')
    release_parser.add_argument('--object', type=str,
                              help='物体ID（默认释放当前物体）')
    release_parser.add_argument('--width', type=float, default=80,
                              help='释放后夹爪宽度(毫米) (默认: 80)')
    
    # ===== 全局选项 =====
    parser.add_argument('--json', action='store_true',
                       help='JSON格式输出')
    parser.add_argument('--verbose', '-v', action='store_true',
                       help='详细输出')
    
    return parser.parse_args()


def print_human_readable(result, verbose=False, command=None):
    """人性化输出结果"""
    if not result:
        print("❌ 无返回结果")
        return
    
    if isinstance(result, bool):
        print("✅ 操作成功" if result else "❌ 操作失败")
        return
    
    if not isinstance(result, dict):
        print(f"⚠️ 未知结果类型: {type(result)}")
        return
    
    success = result.get("success", False)
    
    # 抓取/移动结果
    if command in ['grasp', 'move']:
        if success:
            print("✅ 操作成功")
            if "object_id" in result:
                print(f"   物体: {result['object_id']}")
            if "grasp_width_mm" in result:
                print(f"   夹爪宽度: {result['grasp_width_mm']:.1f} mm")
            if "execution_time" in result:
                print(f"   执行时间: {result['execution_time']:.2f}秒")
            if "cache_hit" in result:
                print(f"   缓存: {'✅ 命中' if result['cache_hit'] else '❌ 未命中'}")
        else:
            print(f"❌ 操作失败: {result.get('error', '未知错误')}")
    
    # 批量抓取结果
    elif command == 'batch':
        print(f"📊 批量抓取结果")
        print(f"   总数: {result.get('total', 0)}")
        print(f"   成功: {result.get('successful', 0)}")
        print(f"   失败: {result.get('failed', 0)}")
        
        if verbose and "results" in result:
            print("\n详细结果:")
            for r in result["results"]:
                status = "✅" if r.get("success") else "❌"
                print(f"   {status} {r.get('object_id')}")
    
    # 状态查询
    elif command == 'status':
        print("📊 当前任务状态")
        print(f"   当前物体: {result.get('current_object', '无')}")
        print(f"   状态: {result.get('status', 'unknown')}")
        print(f"   耗时: {result.get('elapsed_time', '0s')}")
        print(f"   缓存命中: {result.get('cache_hit', False)}")
    
    # 缓存统计
    elif command == 'cache' and 'stats' in result:
        stats = result.get('stats', {})
        print("📊 缓存统计")
        print(f"   命中: {stats.get('hits', 0)}")
        print(f"   未命中: {stats.get('misses', 0)}")
        print(f"   保存: {stats.get('saves', 0)}")
        print(f"   命中率: {stats.get('hit_rate_percent', 0):.1f}%")
    
    # 错误信息
    if not success and "error" in result:
        print(f"   错误: {result['error']}")
    
    if "timestamp" in result:
        print(f"\n时间: {result['timestamp']}")


def main():
    """主函数"""
    args = parse_arguments()
    
    if not HAS_DEPENDENCIES:
        print("❌ 缺少必要依赖，无法运行")
        return 1
    
    try:
        result = None
        
        # ===== grasp 命令 =====
        if args.command == 'grasp':
            ctx = get_planning_context()
            
            if args.object:
                print(f"\n🎯 抓取物体: {args.object}")
                # 【修改】直接传 object_id，让规划器从缓存读位姿
                result = ctx.grasp_object(
                    args.object,
                    strategy=args.strategy,
                    width_mm=args.width
                )
            elif args.pose:
                print(f"\n🎯 抓取位姿: {args.pose[:3]}")
                # 【修改】直接传 pose，让规划器自己算IK
                result = ctx.grasp_pose(
                    args.pose,
                    object_id="cmd_target",
                    strategy=args.strategy,
                    width_mm=args.width or 50
                )
        
        # ===== move 命令 =====
        elif args.command == 'move':
            arm = MoveGroup("panda_arm")
            use_cache = not args.no_cache
            
            if args.pose:
                print(f"\n🚀 移动到指定位姿: {args.pose[:3]}")
                result = arm.move_to_pose(args.pose, use_cache=use_cache, timeout=args.timeout)
            elif args.joints:
                print(f"\n🚀 移动到指定关节: {args.joints[:3]}...")
                result = arm.move_to_joints(args.joints, use_cache=use_cache, timeout=args.timeout)
            elif args.object:
                print(f"\n🚀 移动到物体: {args.object}")
                result = arm.move_to_object(args.object, use_cache=use_cache, timeout=args.timeout)
        
        # ===== batch 命令 =====
        elif args.command == 'batch':
            ctx = get_planning_context()
            print(f"\n📦 批量抓取: {args.objects}")
            result = ctx.batch_grasp(args.objects, strategy=args.strategy)
        
        # ===== status 命令 =====
        elif args.command == 'status':
            ctx = get_planning_context()
            result = ctx.get_current_task_info()
        
        # ===== cache 命令 =====
        elif args.command == 'cache':
            if args.stats:
                result = {"stats": get_execution_stats()}
            elif args.clear:
                success = clear_trajectory_cache()
                result = {"success": success, "message": "缓存已清空" if success else "清空失败"}
        
        # ===== release 命令 =====
        elif args.command == 'release':
            width_m = args.width / 1000.0  # 毫米转米
            result = release_object(args.object, width_m)
        
        # 输出结果
        if result:
            if args.json:
                print(json.dumps(result, indent=2, default=str))
            else:
                print_human_readable(result, args.verbose, args.command)
        
        success = result.get("success", False) if isinstance(result, dict) else bool(result)
        return 0 if success else 1
        
    except KeyboardInterrupt:
        print("\n⏹️ 操作被用户中断")
        return 130
    except Exception as e:
        print(f"❌ 程序错误: {e}")
        if args.verbose:
            import traceback
            traceback.print_exc()
        return 1


if __name__ == "__main__":
    sys.exit(main())